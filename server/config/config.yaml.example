# 配置示例 — 生产环境复制本文件后必须调整：
#   server.log_level: info（生产关闭 debug）
#   server.log_dir: /var/log/aibao（写入系统日志目录）
# 敏感字段（密码等）必须通过环境变量注入，不要写入文件：
#   AIBAO_POSTGRES_PASSWORD
#   AIBAO_REDIS_PASSWORD
#   AIBAO_AUTH_JWT_SECRET
#   AIBAO_CRYPTO_PHONE_AES_KEY
#   AIBAO_CRYPTO_SAFEHASH_SALT
#   AIBAO_LLM_DOUBAO_API_KEY  (生产必须通过环境变量注入豆包 API Key，不要写入文件)
#   AIBAO_TTS_MINIMAX_API_KEY  (Minimax TTS API Key — 严禁写入此文件)
#   AIBAO_TTS_MINIMAX_GROUP_ID (Minimax Group ID)
#   AIBAO_STORAGE_COS_SECRET_ID / AIBAO_STORAGE_COS_SECRET_KEY (腾讯云 COS 密钥 — 严禁写入此文件)
#   AIBAO_STORAGE_COS_BUCKET / AIBAO_STORAGE_COS_APPID
# Production: generate jwt_secret and phone_aes_key with `openssl rand -hex 32`
# All secret values (jwt_secret / phone_aes_key / safehash_salt / postgres.password)
# MUST come from env vars in production, never written to this file.

server:
  port: 8080
  log_dir: ./logs
  log_level: debug

postgres:
  host: 127.0.0.1
  port: 5432
  database: aibao
  user: aibao
  sslmode: disable

redis:
  addr: 127.0.0.1:6379
  db: 0

auth:
  access_ttl_minutes: 1440
  refresh_ttl_minutes: 10080
  # jwt_secret: from env AIBAO_AUTH_JWT_SECRET

sms:
  provider: mock
  code_ttl_seconds: 300
  resend_cooldown_sec: 60

crypto:
  # phone_aes_key: from env AIBAO_CRYPTO_PHONE_AES_KEY (64 hex chars = 32 bytes)
  # safehash_salt: from env AIBAO_CRYPTO_SAFEHASH_SALT

llm:
  provider: doubao
  story_model: doubao-1.5-pro-32k
  intent_model: doubao-lite
  base_url: https://ark.cn-beijing.volces.com/api/v3
  timeout_seconds: 30
  max_retries: 1
  story_temperature: 0.8
  intent_temperature: 0
  daily_budget_yuan: 100.0
  price_input_per_mtok: 0.8
  price_output_per_mtok: 2.0
  generate_rpm: 5
  # api_key: 生产必须通过 AIBAO_LLM_DOUBAO_API_KEY 环境变量注入，不要写在此文件

worker:
  enabled: true
  poll_interval_seconds: 5
  batch_size: 10
  max_attempts: 5
  backoff_base_seconds: 2
  backoff_max_seconds: 600

tts:
  provider: minimax
  base_url: https://api.minimax.chat
  model: speech-01-turbo
  voice_id: female-tianmei  # TBD: confirm via Minimax console; default to a Chinese children-friendly voice
  format: mp3
  sample_rate: 32000
  bitrate: 128000
  speed: 1.0
  timeout_seconds: 60
  # group_id / api_key: 生产必须通过 AIBAO_TTS_MINIMAX_GROUP_ID / AIBAO_TTS_MINIMAX_API_KEY 注入，绝不能写入此文件

storage:
  provider: cos
  region: ap-shanghai
  presigned_ttl_seconds: 900
  upload_timeout_seconds: 30
  # bucket / app_id / secret_id / secret_key: 生产必须通过 AIBAO_STORAGE_COS_* 环境变量注入，绝不能写入此文件
